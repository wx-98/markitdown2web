# ============================================================
# Everything2Markdown (E2M) — 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据实际情况修改
#   cp .env.example .env
# ============================================================

# ======================== 应用基础 ========================
APP_NAME=Everything2Markdown
DEBUG=true
SECRET_KEY=change-me-in-production

# ======================== 服务器 ==========================
HOST=0.0.0.0
PORT=8001

# ======================== 数据库 (MySQL) ==================
# Docker 部署时使用: mysql+aiomysql://e2m:e2m_password@mysql:3306/e2m
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/e2m

# ======================== 文件存储 ========================
STORAGE_PATH=./data/storage
EXPORT_PATH=./data/exports

# ======================== JWT 认证 ========================
JWT_SECRET_KEY=your-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ======================== Google OAuth ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ======================== 邮箱验证码 (SMTP) ================
# 根据收件人邮箱后缀自动选择发件通道：
#   @gmail.com -> Gmail SMTP
#   @qq.com / 其他 -> QQ 邮箱 SMTP

# -- Gmail SMTP --
SMTP_GMAIL_HOST=smtp.gmail.com
SMTP_GMAIL_PORT=587
SMTP_GMAIL_USERNAME=
SMTP_GMAIL_PASSWORD=

# -- QQ 邮箱 SMTP --
# QQ 邮箱需要使用授权码而非登录密码，在 设置 -> 账户 -> POP3/SMTP 中开启并获取
SMTP_QQ_HOST=smtp.qq.com
SMTP_QQ_PORT=587
SMTP_QQ_USERNAME=
SMTP_QQ_PASSWORD=

# ======================== 短信验证码 ======================
# SMS_PROVIDER: aliyun / twilio
SMS_PROVIDER=aliyun

# -- 阿里云短信 --
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# -- Twilio --
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ======================== Stripe 支付 =====================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=

# ======================== 微信支付 ========================
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=

# ======================== 支付宝 ==========================
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# ======================== 定价 ============================
# 金额单位：分
MONTHLY_PRICE_CNY=2900
MONTHLY_PRICE_USD=999

# ============================================================
#                     AI 模型配置
# ============================================================
USE_SHARED_API_CONFIG=true

# ---------- LLM ----------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ---------- VLM ----------
VLM_API_KEY=
VLM_BASE_URL=
VLM_MODEL=gpt-4o

# ---------- ASR ----------
ASR_ENABLED=true
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=whisper-1

# ======================== 视频处理 ========================
MAX_VIDEO_DURATION=3600
MAX_VIDEO_SIZE_MB=500
FRAME_INTERVAL_SECONDS=10

# ======================== 文档处理 ========================
MAX_FILE_SIZE_MB=50
