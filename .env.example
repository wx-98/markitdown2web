# ============================================================
# Everything2Markdown (E2M) — 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据实际情况修改
#   cp .env.example .env
# ============================================================

# ======================== 应用基础 ========================
# 应用名称（显示在 API 文档标题中）
APP_NAME=Everything2Markdown
# 调试模式（true 时会输出 SQL 日志，生产环境务必设为 false）
DEBUG=true
# 密钥（用于签名等，部署时请更换为随机字符串）
SECRET_KEY=change-me-in-production

# ======================== 服务器 ==========================
# 监听地址和端口
HOST=0.0.0.0
PORT=8001

# ======================== 数据库 ==========================
# 默认使用 SQLite，数据文件存放在 ./data/ 下
# 如需 PostgreSQL，改为: postgresql+asyncpg://user:pass@host:5432/e2m
DATABASE_URL=sqlite:///./data/e2m.db

# ======================== 文件存储 ========================
# 上传文件临时存储路径
STORAGE_PATH=./data/storage
# 导出文件存储路径
EXPORT_PATH=./data/exports

# ============================================================
#                     AI 模型配置
# ============================================================
#
# USE_SHARED_API_CONFIG 控制 VLM 和 ASR 是否复用 LLM 的 API 配置：
#   true  → VLM 和 ASR 自动使用 OPENAI_API_KEY / OPENAI_BASE_URL
#   false → VLM 和 ASR 各自使用独立的 KEY / URL（见下方配置）
#
# 典型场景：
#   - 全部使用 OpenAI 官方 API        → USE_SHARED_API_CONFIG=true
#   - LLM 用 OpenAI，VLM 用自建服务   → USE_SHARED_API_CONFIG=false
#   - 各模型走不同的代理/转发地址      → USE_SHARED_API_CONFIG=false
# ============================================================

USE_SHARED_API_CONFIG=true

# ---------- LLM（文本生成 / 总结 / 笔记生成） ----------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
# 推荐模型：gpt-4o / gpt-4o-mini / deepseek-chat 等
LLM_MODEL=gpt-4o

# ---------- VLM（视觉语言模型 / 视频帧分析） ----------
# 仅在 USE_SHARED_API_CONFIG=false 时生效
# 留空则自动回退使用 LLM 的配置
VLM_API_KEY=
VLM_BASE_URL=
# 推荐模型：gpt-4o / claude-sonnet-4-20250514 等支持视觉的模型
VLM_MODEL=gpt-4o

# ---------- ASR（语音识别 / 视频音频转文字） ----------
# 仅在 USE_SHARED_API_CONFIG=false 时生效
# 留空则自动回退使用 LLM 的配置
ASR_API_KEY=
ASR_BASE_URL=
# 推荐模型：whisper-1
ASR_MODEL=whisper-1

# ======================== 视频处理 ========================
# 允许处理的视频最大时长（秒），默认 1 小时
MAX_VIDEO_DURATION=3600
# 允许上传的视频最大体积（MB）
MAX_VIDEO_SIZE_MB=500
# 帧提取间隔（秒），每隔 N 秒提取一帧用于 VLM 分析
FRAME_INTERVAL_SECONDS=10

# ======================== 文档处理 ========================
# 允许上传的文档最大体积（MB）
MAX_FILE_SIZE_MB=50
