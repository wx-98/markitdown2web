FROM node:20-alpine AS build

WORKDIR /app
COPY pptx-frontend/package.json pptx-frontend/package-lock.json* ./
RUN npm install
COPY pptx-frontend/ .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx-pptx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
